# ============================================================================
# GoPlan backend environment template (copy to backend/.env)
#
# Every variable here is [server-only, runtime]: loaded into containers via
# `env_file:` in the compose files, read by Django at process start. None of
# them is baked into an image (backend/.containerignore excludes real env
# files from the build context) — changing values only needs a container
# restart, not a rebuild.
#
# [secret] variables — never commit, log, or echo them:
#   DJANGO_SECRET_KEY, DB_PASSWORD, EMAIL_HOST_PASSWORD, DEEPSEEK_API_KEY,
#   GOPLAN_INTERNAL_PROXY_SECRET
#
# Companion file: backend/db.env (copy from backend/db.env.example) holds the
# PostgreSQL container credentials — POSTGRES_DB/USER/PASSWORD there must match
# DB_NAME/DB_USER/DB_PASSWORD here.
# ============================================================================

# -------- Django Core Flags --------
# DEV values (local / Mailpit):
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Include http://[::1]:3000 for IPv6 loopback — some browsers / Node DNS
# orderings resolve `localhost` to ::1 first. Without this entry the ASGI
# OriginValidator silently rejects WebSocket handshakes from that origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
DJANGO_SECRET_KEY=replace-with-your-own-secret-key
# Optional, dev-only: enable explicit throttle bypass for listed emails. Keep
# disabled unless a local seed/dev account needs repeated auth requests.
DEV_THROTTLE_BYPASS_ENABLED=0
DEV_THROTTLE_BYPASS_EMAILS=
# Shared with the Next.js BFF. Django only trusts forwarded client IP headers
# when this secret matches; generate a long random value for production.
GOPLAN_INTERNAL_PROXY_SECRET=
#
# PRODUCTION — replace the values above with:
#   DJANGO_DEBUG=0
#   DJANGO_ALLOWED_HOSTS=api.example.com,backend,localhost
#     ↳ api.example.com = WebSocket/API ingress domain through your edge/tunnel
#     ↳ backend         = compose DNS if services call Django internally
#     ↳ localhost       = host-local reverse proxy or maintenance access
#   CORS_ALLOWED_ORIGINS=https://app.example.com
#   CSRF_TRUSTED_ORIGINS=https://app.example.com
#   DJANGO_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_urlsafe(50))">
#   DEV_THROTTLE_BYPASS_ENABLED=0   (must stay 0 in production)
#   GOPLAN_INTERNAL_PROXY_SECRET=<same value as frontend/.env.local>
#   DJANGO_SECURE_SSL_REDIRECT=0    (only when HTTPS is enforced at the edge/tunnel)

# -------- PostgreSQL Binding --------
DB_NAME=goplan_db
DB_USER=goplan_user
DB_PASSWORD=replace-with-your-own-db-password
DB_HOST=postgresql-goplan
DB_PORT=5432
# Keep 0 for ASGI/Daphne deployments without PgBouncer to avoid idle
# persistent connections exhausting PostgreSQL on bursty traffic.
DB_CONN_MAX_AGE=0

# -------- Redis (Channel Layer) --------
REDIS_URL=redis://redis-messaging:6379/0
REDIS_CACHE_URL=redis://redis-messaging:6379/3

# -------- Email --------
# DEV (Mailpit): use the service name from podman-compose.yml (not
# container_name) as the hostname — Compose DNS resolves service names on the
# internal network. Mailpit needs no auth, so leave USER/PASSWORD empty.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=0
EMAIL_USE_SSL=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@goplan.app
#
# PRODUCTION SMTP example — replace the values above with:
#   EMAIL_HOST=smtp.example.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=1
#   EMAIL_USE_SSL=0
#   EMAIL_HOST_USER=<smtp-username>
#   EMAIL_HOST_PASSWORD=<smtp-app-password-or-token>
#   DEFAULT_FROM_EMAIL=GoPlan <noreply@example.com>
# Use EMAIL_PORT=465 with EMAIL_USE_SSL=1 and EMAIL_USE_TLS=0 only if your
# provider requires implicit TLS.

# -------- Frontend --------
FRONTEND_BASE_URL=http://localhost:3000
# Public web origin used for share links. Production must set this or FRONTEND_BASE_URL.
PUBLIC_APP_BASE_URL=http://localhost:3000
#
# PRODUCTION — replace the values above with:
#   FRONTEND_BASE_URL=https://app.example.com
#   PUBLIC_APP_BASE_URL=https://app.example.com

# -------- Celery / AI Worker --------
CELERY_BROKER_URL=redis://redis-messaging:6379/1
CELERY_RESULT_BACKEND=redis://redis-messaging:6379/2
CELERY_TASK_TIME_LIMIT=120
CELERY_TASK_SOFT_TIME_LIMIT=90

# -------- DeepSeek AI --------
DEEPSEEK_API_KEY=replace-with-real-key-locally
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=4000
GOPLAN_AI_THINKING_ENABLED=1
GOPLAN_AI_REASONING_EFFORT=high
GOPLAN_AI_LOCK_TTL_SECONDS=120
GOPLAN_AI_MAX_ATTEMPTS=3
