# -------- Django Core Flags --------
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Include http://[::1]:3000 for IPv6 loopback — some browsers / Node DNS
# orderings resolve `localhost` to ::1 first. Without this entry the ASGI
# OriginValidator silently rejects WebSocket handshakes from that origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
DJANGO_SECRET_KEY=replace-with-your-own-secret-key
# Optional, dev-only: enable explicit throttle bypass for listed emails. Keep
# disabled unless a local seed/dev account needs repeated auth requests.
DEV_THROTTLE_BYPASS_ENABLED=0
DEV_THROTTLE_BYPASS_EMAILS=

# -------- PostgreSQL Binding --------
DB_NAME=goplan_db
DB_USER=goplan_user
DB_PASSWORD=replace-with-your-own-db-password
DB_HOST=postgresql-goplan
DB_PORT=5432

# -------- Redis (Channel Layer) --------
REDIS_URL=redis://redis-messaging:6379/0

# -------- Email (Mailpit Dev) --------
# Use the service name from podman-compose.yml (not container_name) as the
# hostname — Compose DNS resolves service names on the internal network.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=0

# -------- Frontend --------
FRONTEND_BASE_URL=http://localhost:3000
# Public web origin used for share links. Production must set this or FRONTEND_BASE_URL.
PUBLIC_APP_BASE_URL=http://localhost:3000

# -------- Celery / AI Worker --------
CELERY_BROKER_URL=redis://redis-messaging:6379/1
CELERY_RESULT_BACKEND=redis://redis-messaging:6379/2
CELERY_TASK_TIME_LIMIT=120
CELERY_TASK_SOFT_TIME_LIMIT=90

# -------- DeepSeek AI --------
DEEPSEEK_API_KEY=replace-with-real-key-locally
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=4000
GOPLAN_AI_THINKING_ENABLED=1
GOPLAN_AI_REASONING_EFFORT=high
GOPLAN_AI_LOCK_TTL_SECONDS=120
GOPLAN_AI_MAX_ATTEMPTS=3
