# -------- Base Image --------
FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# -------- Build Stage --------
FROM node:22-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://backend:8000
ARG NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
ARG NEXT_PUBLIC_WS_URL=ws://localhost:8000
ARG NEXT_ALLOWED_DEV_ORIGINS=
ARG NEXT_ENABLE_HSTS=0

ENV NEXT_TELEMETRY_DISABLED=1 \
    NEXT_PRIVATE_BUILD_WORKER_COUNT=1 \
    NODE_OPTIONS=--max-old-space-size=1536 \
    NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL \
    NEXT_PUBLIC_APP_BASE_URL=$NEXT_PUBLIC_APP_BASE_URL \
    NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL \
    NEXT_ALLOWED_DEV_ORIGINS=$NEXT_ALLOWED_DEV_ORIGINS \
    NEXT_ENABLE_HSTS=$NEXT_ENABLE_HSTS

COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

# -------- Runtime Stage --------
FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3000

# Standalone output keeps the image free of source code and devDependencies.
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

CMD ["node", "server.js"]
