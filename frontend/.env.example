# ============================================================================
# GoPlan frontend environment template (copy to frontend/.env.local)
#
# Variable classification:
#
#   [public, build-time]  NEXT_PUBLIC_* values are INLINED into the JS bundle
#                         when `next build` runs. They are visible to every
#                         browser — never put secrets in them.
#                         - Dev (`npm run dev`): read from this file at startup.
#                         - Production image: read from Containerfile build args,
#                           which podman-compose.prod.yml interpolates from the
#                           repo-root `.env` file (gitignored) or shell env —
#                           NOT from frontend/.env.local. Changing them requires
#                           rebuilding the image.
#
#   [server-only, runtime] Read by Next.js Route Handlers (BFF) on the server
#                          at request time. Never exposed to the browser. In
#                          production they reach the container via `env_file:`
#                          in podman-compose.prod.yml; changing them only needs
#                          a container restart.
#
#   [secret]               Must never be committed, logged, or NEXT_PUBLIC_-ed.
# ============================================================================

# -------- BFF -> Django --------
# [public name, server-only usage, build-time] Base URL Route Handlers use to
# call Django. Browser code must use BFF routes (/api/*), never call Django
# directly. Despite the NEXT_PUBLIC_ prefix it is only consumed server-side
# (shared/http/config.ts, next.config.ts rewrites).
# DEV: Django on localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# PRODUCTION (compose default — usually no need to set anywhere):
#   NEXT_PUBLIC_API_BASE_URL=http://backend:8000

# [server-only, runtime, secret] Shared with backend/.env. Route Handlers send
# this header so Django can trust the forwarded real client IP for throttling.
# Generate a long random value; must match GOPLAN_INTERNAL_PROXY_SECRET in
# backend/.env.
GOPLAN_INTERNAL_PROXY_SECRET=

# -------- Public web origin --------
# [public, build-time] Used for public share page metadata/server fetches.
# DEV:
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
# PRODUCTION (set in repo-root .env for the image build):
#   NEXT_PUBLIC_APP_BASE_URL=https://app.example.com

# -------- Browser WebSocket --------
# [public, build-time] Browser-side WebSocket base URL; the app appends
# /ws/realtime itself. This does not change the HTTP/BFF rule, and it does not
# bless query-string auth as a default pattern.
# DEV:
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# PRODUCTION (set in repo-root .env for the image build) — must use wss://
# (secure WebSocket over TLS) so the browser doesn't block the upgrade on an
# HTTPS page:
#   NEXT_PUBLIC_WS_URL=wss://api.example.com

# -------- Next.js server behavior --------
# [server-only, build-time] Extra origins allowed by the Next.js dev server.
# Usually empty in production. For a homelab domain, set this only if
# `next dev` needs to accept that host.
NEXT_ALLOWED_DEV_ORIGINS=

# [server-only, build-time] Emits Strict-Transport-Security headers when 1.
# Keep 0 for local HTTP development; production behind HTTPS must set 1
# (in repo-root .env for the image build).
NEXT_ENABLE_HSTS=0

# -------- HERE location search (local demo) --------
# [server-only, runtime] Local-only HERE demo toggle. Keep false outside local
# development so destination search falls back to plain text.
ENABLE_HERE_LOCATION_SEARCH=false
# [server-only, runtime, secret] HERE API key lives in frontend/.env.local only
# when the local demo needs autocomplete.
# HERE_API_KEY=
# [server-only, runtime] Optional safety rails for HERE usage.
# HERE_LOCATION_SEARCH_MAX_REQUESTS_PER_MINUTE=30
# HERE_LOCATION_SEARCH_SUGGEST_CACHE_TTL_MS=60000
# HERE_LOCATION_SEARCH_LOOKUP_CACHE_TTL_MS=300000
