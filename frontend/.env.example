# Server-side BFF base URL — used by Next.js Route Handlers to call Django.
# Browser code must use BFF routes (/api/*), never call Django directly.
# DEV: reach Django on the container network via service name.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# PRODUCTION: Next.js runs on the host, Django runs in container (port 8000
# mapped to host). Route Handlers call Django at localhost — no container DNS needed.
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public GoPlan web origin — used for public share page metadata/server fetches.
# DEV:
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
# PRODUCTION (goplan.quangmin.me):
#   NEXT_PUBLIC_APP_BASE_URL=https://goplan.quangmin.me

# Local-only HERE demo toggle.
# Keep this false outside local development so destination search falls back to plain text.
ENABLE_HERE_LOCATION_SEARCH=false
# HERE API key is server-only and should live in frontend/.env.local when the local demo needs autocomplete.
# HERE_API_KEY=
# Optional: tune the local safety rails for HERE usage.
# HERE_LOCATION_SEARCH_MAX_REQUESTS_PER_MINUTE=30
# HERE_LOCATION_SEARCH_SUGGEST_CACHE_TTL_MS=60000
# HERE_LOCATION_SEARCH_LOOKUP_CACHE_TTL_MS=300000

# Browser-side WebSocket URL for the current realtime implementation.
# This does not change the HTTP/BFF rule, and it does not bless query-string auth as a default pattern.
# DEV:
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# PRODUCTION — must use wss:// (secure WebSocket over TLS) so the browser
# doesn't block the upgrade on an HTTPS page:
#   NEXT_PUBLIC_WS_URL=wss://api.quangmin.me
